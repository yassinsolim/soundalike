# Copy this file to ".env" and fill in your own values.
# The .env file is git-ignored, so your keys stay local.

# --- Spotify (Phase 2) ---
# Create a free app at https://developer.spotify.com/dashboard
# Add this exact Redirect URI to the app settings: http://127.0.0.1:8888/callback
# No client secret is needed: we use the Authorization Code + PKCE flow.
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- Last.fm (Phase 3) ---
# Get a free API key at https://www.last.fm/api/account/create
LASTFM_API_KEY=
